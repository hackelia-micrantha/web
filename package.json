{
  "name": "micrantha-web",
  "private": true,
  "description": "The Minimal House Remix Stack to setup Remix with minimal typsescript, tailwind, linting, and formatting. Worry about storage, testing, or deployment later.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "run-s build:*",
    "build:css": "npm run generate:css -- --minify",
    "build:remix": "remix build",
    "dev": "run-p dev:*",
    "dev:css": "npm run generate:css -- --watch",
    "dev:remix": "remix dev",
    "generate:css": "npx @tailwindcss/cli -i ./app/styles/app.css -o ./public/tailwind.css",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "start": "remix-serve build/index.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:mobile": "playwright test --project=mobile-chromium",
    "typecheck": "tsc -b",
    "deploy:cloudflare": "yarn typecheck && yarn build && npx wrangler pages deploy public --project-name ${CLOUDFLARE_PAGES_PROJECT:-micrantha-web} --branch ${CLOUDFLARE_PAGES_BRANCH:-main} --upload-source-maps"
  },
  "dependencies": {
    "@remix-run/node": "2.17.4",
    "@remix-run/react": "2.17.4",
    "@remix-run/serve": "2.17.4",
    "isbot": "^4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-websitecarbon-badge": "^1.0.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/compat": "2.0.3",
    "@playwright/test": "^1.54.2",
    "@remix-run/dev": "2.17.4",
    "@remix-run/eslint-config": "2.17.4",
    "@tailwindcss/cli": "4.2.2",
    "@types/minimatch": "^6.0.0",
    "@types/react": "18.3.27",
    "@types/react-dom": "18.3.7",
    "baseline-browser-mapping": "^2.10.12",
    "eslint": "9.39.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "npm-run-all": "^4.1.5",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwindcss": "4.2.2",
    "typescript": "^5.1.6",
    "typescript-eslint": "8.57.1"
  },
  "engines": {
    "node": ">=18"
  }
}
